# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# =============================================================================
# Virtual environment
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Package build artifacts
# =============================================================================
*.egg-info/
dist/
build/
*.egg
.eggs/

# =============================================================================
# Secrets — never commit
# =============================================================================
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.yml

# =============================================================================
# Backend data — generated at runtime, too large for git
# =============================================================================
backend/data/raw/
backend/data/analytics/
backend/data/storage/
backend/data/positions/
backend/data/manifests/
backend/data/cache/
backend/data/metadata.db

# Keep the skeleton visible
!backend/data/.gitkeep

# =============================================================================
# Runtime outputs
# =============================================================================
logs/
artifacts/
backend/logs/
backend/artifacts/

# =============================================================================
# Frontend — build outputs and dependencies
# =============================================================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.output/
frontend/.vinxi/
frontend/.tanstack/
frontend/.nitro/
frontend/*.local
frontend/.wrangler/
frontend/.dev.vars

# Also catch npm/bun lock conflicts (keep only one lock per project)
frontend/package-lock.json

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =============================================================================
# Type checking / linting
# =============================================================================
.mypy_cache/
.ruff_cache/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
!.vscode/extensions.json
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =============================================================================
# Logs (npm, yarn, pnpm)
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Claude Code local config
# =============================================================================
.claude/
