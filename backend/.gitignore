# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# =============================================================================
# Virtual environment
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# Package build artifacts
# =============================================================================
*.egg-info/
dist/
build/
*.egg
.eggs/

# =============================================================================
# Secrets — never commit
# =============================================================================
.env
.env.*
*.pem
*.key
secrets.yaml
secrets.yml

# =============================================================================
# Local data — generated at runtime, too large for git
# =============================================================================
data/raw/
data/analytics/
data/storage/
data/positions/
data/manifests/
data/metadata.db

# Keep the data/ directory itself tracked (so the layout is visible)
!data/.gitkeep

# =============================================================================
# Runtime outputs — regenerated on every run
# =============================================================================
logs/
artifacts/

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =============================================================================
# Type checking / linting
# =============================================================================
.mypy_cache/
.ruff_cache/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Claude Code local config
# =============================================================================
.claude/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
