# =============================================================================
# vol-infra .gitignore
# =============================================================================

# Secrets and local config overrides
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.eggs/
*.egg

# Tooling
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Runtime artifacts
logs/
artifacts/
data/
*.log
*.parquet
*.feather

# Lock files: keep uv.lock checked in; do not commit pip-tools intermediate output
# (uv.lock is the source of truth for reproducibility)

# Notebooks: do not commit checkpoints
.ipynb_checkpoints/
