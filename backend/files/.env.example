# =============================================================================
# vol-infra environment variables
# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit secrets or account numbers to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# IBKR connectivity
# -----------------------------------------------------------------------------
# Host where TWS or IB Gateway is reachable.
# Localhost when running on the same machine.
VOL_INFRA_IBKR__HOST=127.0.0.1

# Port:
#   TWS live       = 7496
#   TWS paper      = 7497
#   IB Gateway live= 4001
#   IB Gateway paper= 4002
# Default below is IB Gateway paper. Override per environment.
VOL_INFRA_IBKR__PORT=4002

# Application-level client ID. Each service must use a unique ID per session.
# Range 1..32 is typical for retail; pick a convention and document it.
# Reserved here: 1=bootstrap, 10=underlying collector, 11=option collector, 20=universe service.
VOL_INFRA_IBKR__CLIENT_ID=1

# IBKR account code (e.g. DU1234567 for paper, U1234567 for live).
# Leave blank to let TWS/Gateway use its default account.
VOL_INFRA_IBKR__ACCOUNT=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# Environment label: development | staging | production
VOL_INFRA_RUNTIME__ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
VOL_INFRA_RUNTIME__LOG_LEVEL=INFO

# Where to write logs and artifacts (absolute or repo-relative path).
VOL_INFRA_RUNTIME__ARTIFACTS_DIR=./artifacts
VOL_INFRA_RUNTIME__LOGS_DIR=./logs
